# ==============================================================================
# react-fastapi-chat — .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# Environment variables — NEVER commit these
# ------------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ------------------------------------------------------------------------------
# Python / FastAPI backend
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
venv/
.venv/
env/
.Python
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# SQLite dev database
*.db
*.sqlite3

# ------------------------------------------------------------------------------
# Node / React frontend
# ------------------------------------------------------------------------------
node_modules/
/client/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ------------------------------------------------------------------------------
# IDE & OS
# ------------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db