REACT_APP_API_URL=localhost:8000
REACT_APP_SOCKET_PATH=/ws
BROWSER=none

# ==============================================================================
# react-fastapi-chat — Frontend Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# IMPORTANT: React only exposes variables prefixed with REACT_APP_ to the
# browser bundle. All other variables are ignored at build time.
# ==============================================================================


# ------------------------------------------------------------------------------
# Backend API
# ------------------------------------------------------------------------------

# Base HTTP URL of the FastAPI backend.
# Used for any REST calls (health check, auth, message history, etc.)
REACT_APP_API_URL=http://localhost:8000

# WebSocket URL of the FastAPI backend.
# Must use ws:// locally and wss:// in production (TLS).
# The app will append /{username} to this base URL at runtime.
REACT_APP_WS_URL=ws://localhost:8000/ws


# ------------------------------------------------------------------------------
# App Behaviour
# ------------------------------------------------------------------------------

# Maximum message length (characters) enforced in the UI input.
REACT_APP_MAX_MESSAGE_LENGTH=500

# Number of past messages to load on room join (requires backend persistence).
REACT_APP_MESSAGE_HISTORY_LIMIT=50

# WebSocket reconnect: base delay in milliseconds before first retry.
REACT_APP_WS_RECONNECT_BASE_DELAY_MS=1000

# WebSocket reconnect: maximum delay cap in milliseconds (exponential backoff).
REACT_APP_WS_RECONNECT_MAX_DELAY_MS=30000

# WebSocket reconnect: maximum number of retry attempts before giving up.
REACT_APP_WS_RECONNECT_MAX_ATTEMPTS=10


# ------------------------------------------------------------------------------
# Feature Flags
# ------------------------------------------------------------------------------

# Show connection status indicator in the UI (true | false).
REACT_APP_SHOW_CONNECTION_STATUS=true

# Enable message timestamps in the chat UI (true | false).
REACT_APP_SHOW_TIMESTAMPS=true